<Window x:Class="klk2.AviokompanijaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Aviokompanija" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Height="50" Padding="20,0">
            <TextBlock x:Name="tbNaslov" Text="Nova Aviokompanija"
                       FontSize="18" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White" Height="56"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Sacuvaj" Background="#4CAF50" Foreground="White"
                        Height="36" MinWidth="100" Margin="0,0,8,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnSacuvaj_Click"/>
                <Button Content="Otkazi" Background="#757575" Foreground="White"
                        Height="36" MinWidth="100"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnOtkazi_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20">
            <TextBlock Text="Naziv" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="tbNaziv" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

            <TextBlock Text="Država" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="tbDrzava" Style="{StaticResource InputStyle}"/>
        </StackPanel>
    </DockPanel>
</Window>
