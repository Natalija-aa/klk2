<Window x:Class="klk2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Aviokompanija - Upravljanje Letovima"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1A237E" Height="60" Padding="20,0">
            <TextBlock Text="&#9992;  Aviokompanija - Letovi" Style="{StaticResource HeaderStyle}"/>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="White" Height="56"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnDodaj" Content="+ Dodaj"
                        Background="#4CAF50" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnDodaj_Click"/>
                <Button x:Name="btnIzmeni" Content="&#9998; Izmeni"
                        Background="#1565C0" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnIzmeni_Click"/>
                <Button x:Name="btnObrisi" Content="&#128465; Obrisi"
                        Background="#C62828" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnObrisi_Click"/>
                <Button x:Name="btnDetalji" Content="&#128269; Detalji"
                        Background="#6A1B9A" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnDetalji_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Margin="15" Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="dgLetovi"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="13"
                      Background="White"
                      BorderThickness="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      AlternatingRowBackground="#F8F9FF"
                      RowBackground="White"
                      Margin="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#3949AB"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Broj Leta" Binding="{Binding BrojLeta}" Width="110"/>
                    <DataGridTextColumn Header="Relacija" Binding="{Binding Relacija}" Width="*"/>
                    <DataGridTextColumn Header="Datum i Vreme"
                                        Binding="{Binding DatumVreme, StringFormat=\{0:dd.MM.yyyy HH:mm\}}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Cena (EUR)"
                                        Binding="{Binding CenaKarte, StringFormat=\{0:N2\}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Aviokompanija"
                                        Binding="{Binding Aviokompanija.Naziv}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
