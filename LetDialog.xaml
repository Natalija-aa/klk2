<Window x:Class="klk2.LetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Let" Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1A237E" Height="50" Padding="20,0">
            <TextBlock x:Name="tbNaslov" Text="Novi Let"
                       FontSize="18" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <Border DockPanel.Dock="Bottom" Background="White" Height="56"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Sacuvaj" Background="#4CAF50" Foreground="White"
                        Height="36" MinWidth="100" Margin="0,0,8,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnSacuvaj_Click"/>
                <Button Content="Otkazi" Background="#757575" Foreground="White"
                        Height="36" MinWidth="100"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnOtkazi_Click"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Aviokompanija" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cbAviokompanija" Height="34" FontSize="13"
                          DisplayMemberPath="Naziv" SelectedValuePath="Id"
                          Margin="0,0,0,12" Padding="8,0"
                          BorderBrush="#BDBDBD"/>

                <TextBlock Text="Broj Leta" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="tbBrojLeta" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                <TextBlock Text="Relacija" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="tbRelacija" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                <TextBlock Text="Datum i Vreme" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpDatum" Height="34" FontSize="13"
                            Margin="0,0,0,12" BorderBrush="#BDBDBD"/>

                <TextBlock Text="Cena Karte (EUR)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="tbCena" Style="{StaticResource InputStyle}" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
