<Window x:Class="klk2.AviokompanijaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Upravljanje Aviokomapnijama"
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Height="50" Padding="20,0">
            <TextBlock Text="&#9992;  Aviokompanije" Style="{StaticResource HeaderStyle}"/>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" Height="56"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnDodaj" Content="+ Dodaj"
                        Background="#4CAF50" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnDodaj_Click"/>
                <Button x:Name="btnIzmeni" Content="&#9998; Izmeni"
                        Background="#1565C0" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnIzmeni_Click"/>
                <Button x:Name="btnObrisi" Content="&#128465; Obrisi"
                        Background="#C62828" Foreground="White"
                        Height="36" MinWidth="90" Margin="5,0"
                        FontSize="13" FontWeight="SemiBold"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="btnObrisi_Click"/>
            </StackPanel>
        </Border>

        <Border Margin="15" Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="dgAviokompanije"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="13"
                      Background="White"
                      BorderThickness="0"
                      AlternatingRowBackground="#F8F9FF"
                      RowBackground="White">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#3949AB"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                    <DataGridTextColumn Header="Država" Binding="{Binding Drzava}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
