<Window x:Class="klk2.DetaljiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Detalji Leta" Height="400" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <Style x:Key="LabelKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="LabelValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Height="50" Padding="20,0">
            <TextBlock Text="Detalji Leta" FontSize="18" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White" Height="56"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,0">
            <Button Content="Zatvori" Background="#1565C0" Foreground="White"
                    Height="36" MinWidth="100" HorizontalAlignment="Right"
                    FontSize="13" FontWeight="SemiBold"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="btnZatvori_Click"/>
        </Border>

        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="8" Padding="16"
                        BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="AVIOKOMPANIJA" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbAviokompanija" Style="{StaticResource LabelValue}"/>
                        <TextBlock Text="DRZAVA" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbDrzava" Style="{StaticResource LabelValue}" Margin="0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="16"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="BROJ LETA" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbBrojLeta" Style="{StaticResource LabelValue}"/>
                        <TextBlock Text="RELACIJA" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbRelacija" Style="{StaticResource LabelValue}"/>
                        <TextBlock Text="DATUM I VREME" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbDatumVreme" Style="{StaticResource LabelValue}"/>
                        <TextBlock Text="CENA KARTE" Style="{StaticResource LabelKey}"/>
                        <TextBlock x:Name="tbCenaKarte" Style="{StaticResource LabelValue}" Margin="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
